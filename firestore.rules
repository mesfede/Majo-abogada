rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Seguridad por defecto: Denegar todo
    match /{document=**} {
      allow read, write: if false;
    }

    // Funciones de validación
    function isSignedIn() {
      return request.auth != null;
    }

    function isLawyer() {
      return isSignedIn() && 
             (request.auth.token.email.lower() == "mesfede@gmail.com" || 
              request.auth.token.email.lower() == "mjlizaso@gmail.com");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidConsulta(consulta) {
      return consulta.fullName is string && consulta.fullName.size() <= 200 &&
             consulta.email is string && consulta.email.size() <= 320 &&
             consulta.message is string && consulta.message.size() <= 10000;
    }

    // Colección de consultas
    match /consultas/{consultaId} {
      // Cualquiera puede enviar una consulta
      allow create: if isValidId(consultaId) && 
                       isValidConsulta(request.resource.data) &&
                       request.resource.data.status == "pendiente";

      // Solo los abogados pueden leer, actualizar y eliminar
      allow read, update, delete: if isLawyer();
    }
  }
}
